# ===== GitLab data source =====
# auto   : thử gọi API trực tiếp, fail thì đọc data/gitlab-summary.json, fail nữa thì demo
# api    : Plan A — GitLab công ty truy cập được từ internet (Vercel gọi thẳng)
# static : Plan B — GitLab sau firewall, dùng GitLab CI sync file JSON về repo này
GITLAB_DATA_MODE=auto

# Plan A only — KHÔNG commit file .env, token chỉ nằm trong Vercel env vars
GITLAB_BASE_URL=https://gitlab.your-company.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_USERNAME=hoang.nguyen

# Allowlist: project nào được hiện TÊN THẬT trên portfolio (path_with_namespace).
# Mọi project khác chỉ được đếm ẩn danh là "private project".
GITLAB_PUBLIC_PROJECTS=hoang/japanese-n3-app,hoang/services-monorepo
